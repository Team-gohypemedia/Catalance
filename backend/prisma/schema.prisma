generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  CLIENT
  FREELANCER
  ADMIN
  PROJECT_MANAGER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_APPROVAL
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  AWAITING_PAYMENT
  COMPLETED
  PAUSED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  REPLACED
}

enum DisputeStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ProjectTaskStatus {
  TO_DO
  IN_PROGRESS
  REVIEW
  DONE
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EngagementLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
  GOLD
}

enum EngagementQuestionType {
  MCQ
  TRUE_FALSE
  SCENARIO_MCQ
}

enum EngagementQuestionCategory {
  CLIENT_COMMUNICATION
  SCOPE_MANAGEMENT
  DELIVERY
  QUALITY_CONTROL
  PLATFORM_RULES
  BUSINESS_BASICS
}

enum EngagementDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum EngagementQuestionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

enum DailyQuestionSetStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum PointsLedgerType {
  EARN
  SPEND
  ADJUSTMENT
  REVERSAL
}

model User {
  id                   String              @id @default(cuid())
  email                String              @unique
  fullName             String
  phoneNumber          String?
  passwordHash         String
  role                 UserRole            @default(FREELANCER)
  roles                String[]            @default([])
  status               UserStatus          @default(ACTIVE)
  resetPasswordToken   String?             @unique
  resetPasswordExpires DateTime?
  fcmToken             String? // Firebase Cloud Messaging token for push notifications
  otpCode              String?
  otpExpires           DateTime?
  onboardingComplete   Boolean             @default(false)
  isVerified           Boolean             @default(false)
  suspendedAt          DateTime? // Track when user was suspended for 90-day deletion countdown
  phone                String? // Contact number
  avatar               String? // Profile image URL
  clientProfile        ClientProfile?
  freelancerProfile    FreelancerProfile?
  managerProfile       ManagerProfile?
  freelancerProjects   FreelancerProject[]
  marketplace          Marketplace[]
  freelancerSkills     FreelancerSkill[]
  engagementProfile    EngagementProfile?
  engagementSessions   EngagementAnswerSession[] @relation("EngagementAnswerUser")
  engagementLedgers    PointsLedger[]             @relation("EngagementPointsUser")
  engagementReport     EngagementProcessReport?
  engagementBadges     EngagementUserBadge[]      @relation("EngagementBadgeUser")
  engagementPersonalizedQuestions EngagementPersonalizedQuestion[]

  ownedProjects           Project[]          @relation("ProjectOwner")
  managedProjects         Project[]          @relation("ProjectManager")
  closureVerifiedProjects Project[]          @relation("ProjectClosureVerifier")
  proposals               Proposal[]
  createdChats            ChatConversation[] @relation("ChatCreator")
  sentMessages            ChatMessage[]      @relation("ChatSender")
  raisedDisputes          Dispute[]          @relation("DisputeRaiser")
  managedDisputes         Dispute[]          @relation("DisputeManager")

  authoredInternalReviews InternalFreelancerReview[] @relation("ReviewAuthor")
  subjectInternalReviews  InternalFreelancerReview[] @relation("ReviewSubject")
  raisedEscalations       AdminEscalation[]          @relation("EscalationRaiser")
  profileUpdateRequests   ProfileUpdateRequest[]     @relation("ProfileUpdateUser")
  reviewedProfileUpdates  ProfileUpdateRequest[]     @relation("ProfileUpdateReviewer")
  milestoneApprovals      MilestoneApproval[]        @relation("MilestoneApprover")
  approvedEngagementQuestions EngagementQuestion[]     @relation("EngagementQuestionApprover")
  approvedDailyQuestionSets   DailyQuestionSet[]       @relation("DailyQuestionSetApprover")
  engagementAdminAudits       EngagementAdminAuditLog[] @relation("EngagementAuditAdmin")
  engagementTargetAudits      EngagementAdminAuditLog[] @relation("EngagementAuditTargetUser")

  notifications       Notification[]
  availabilitySlots   ManagerAvailability[] @relation("ManagerAvailability")
  bookedAppointments  Appointment[]         @relation("AppointmentBooker")
  managedAppointments Appointment[]         @relation("AppointmentManager")
  payments            Payment[]             @relation("FreelancerPayments")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model FreelancerProfile {
  userId                      String   @id
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName                 String?
  openToWork                  Boolean  @default(true)
  isVerified                  Boolean  @default(false)
  rating                      Decimal? @default(0) @db.Decimal(3, 1)
  reviewCount                 Int      @default(0)
  experienceYears             Int?     @default(0)
  workExperience              Json?    @default("[]")
  services                    String[] @default([])
  resume                      String?
  profileRole                 String?
  professionalBio             String?  @db.Text
  deliveryPolicyAccepted      Boolean  @default(false)
  communicationPolicyAccepted Boolean  @default(false)
  acceptInProgressProjects    Boolean?
  city                        String?
  country                     String?
  username                    String?
  languages                   String[] @default([])
  profilePhoto                String?
  coverImage                  String?
  serviceDetails              Json     @default("{}")
  socialMediaLinks            Json?    @default("{}")
  serviceTitle               String?
  serviceCategory            String?   @map("ServiceCategory")
  serviceExperience          String?
  serviceDescription         String?   @db.Text
  deliveryTimeline           String?   @map("serviceDeliveryTimeline")
  startingPrice              String?   @map("serviceStartingPrice")
  serviceKeywords            String[]  @default([]) @map("servicePositiveKeyword")
  serviceMedia               Json?     @default("[]")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model ClientProfile {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileDetails Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ManagerProfile {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileDetails Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Marketplace {
  id             String   @id @default(cuid())
  freelancerId   String
  freelancer     User     @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  serviceKey     String   @default("")
  service        String   @default("")
  serviceDetails Json     @default("{}")
  isFeatured     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([freelancerId, serviceKey])
  @@unique([freelancerId, service])
  @@index([serviceKey])
  @@index([freelancerId])
  @@index([isFeatured])
}

model Project {
  id                       String        @id @default(cuid())
  title                    String
  description              String        @db.Text
  budget                   Int?
  proposalContent          String?       @db.Text
  proposalJson             Json?
  freelancerMatchingJson   Json?
  isAgencyProposal         Boolean       @default(false)
  serviceKey               String?
  clientName               String?
  businessName             String?
  serviceType              String?
  projectOverview          String?       @db.Text
  primaryObjectives        String[]      @default([])
  featuresDeliverables     String[]      @default([])
  timeline                 String?
  budgetSummary            String?
  websiteType              String?
  designStyle              String?
  websiteBuildType         String?
  frontendFramework        String?
  backendTechnology        String?
  databaseType             String?
  hosting                  String?
  pageCount                String?
  creativeType             String?
  volume                   String?
  engagementModel          String?
  brandStage               String?
  brandDeliverables        String[]      @default([])
  targetAudience           String?
  businessCategory         String?
  targetLocations          String[]      @default([])
  seoGoals                 String[]      @default([])
  duration                 String?
  appType                  String?
  appFeatures              String[]      @default([])
  platformRequirements     String[]      @default([])
  status                   ProjectStatus @default(DRAFT)
  progress                 Int           @default(0)
  spent                    Int           @default(0)
  completedTasks           Json          @default("[]")
  verifiedTasks            Json          @default("[]")
  notes                    String?       @db.Text
  owner                    User          @relation("ProjectOwner", fields: [ownerId], references: [id])
  ownerId                  String
  manager                  User?         @relation("ProjectManager", fields: [managerId], references: [id])
  managerId                String?
  freelancerChangeCount    Int           @default(0)
  freelancerChangeRequests Json          @default("[]")

  proposals          Proposal[]
  disputes           Dispute[]
  appointments       Appointment[]
  payments           Payment[]
  tasks              ProjectTask[]
  internalReviews    InternalFreelancerReview[]
  adminEscalations   AdminEscalation[]
  milestoneApprovals MilestoneApproval[]
  externalLink       String? // Project link (e.g. project URL)

  paymentPlanVersion           String    @default("v1")
  closureHandoverConfirmed     Boolean   @default(false)
  closureDeliverablesConfirmed Boolean   @default(false)
  closureReceiptConfirmed      Boolean   @default(false)
  closureNoIssuesConfirmed     Boolean   @default(false)
  closureVerifiedById          String?
  closureVerifiedBy            User?     @relation("ProjectClosureVerifier", fields: [closureVerifiedById], references: [id])
  closureVerifiedAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([managerId])
  @@index([managerId, status])
  @@map("OnGoingProjects")
}

model FreelancerProject {
  id                         String   @id @default(cuid())
  freelancerId               String
  freelancer                 User     @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  serviceKey                 String?
  serviceName                String?
  professionalTitle          String?
  languages                  String[] @default([])
  industriesOrNiches         String[] @default([])
  yearsOfExperienceInService String?
  serviceSpecializations     String[] @default([])
  activeTechnologies         String[] @default([])
  averageProjectPriceRange   String?
  projectComplexityLevel     String?
  acceptInProgressProjects   String?
  title                      String
  description                String?  @db.Text
  link                       String?
  readme                     String?
  fileName                   String?
  fileUrl                    String?
  role                       String?
  timeline                   String?
  budget                     Int?
  tags                       String[] @default([])
  techStack                  String[] @default([])
  sortOrder                  Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([freelancerId])
  @@index([freelancerId, serviceKey])
  @@map("MatchingProjects")
}

model CompletedProject {
  id                  String   @id @default(cuid())
  originalProjectId   String?  @map("ongoingProjectId")
  title               String
  description         String?  @db.Text
  budget              Int?
  budgetMin           Int?
  budgetMax           Int?
  spent               Int      @default(0)
  ownerId             String?
  managerId           String?
  clientSnapshot      Json     @default("{}")
  freelancerIds       String[] @default([])
  freelancerSnapshots Json     @default("[]")
  serviceKey          String?
  serviceType         String?
  niche               String?
  projectType         String?
  timeline            String?
  skills              String[] @default([])
  tags                String[] @default([])
  matchingSeed        Json     @default("{}")
  completedAt         DateTime @default(now())
  archivedData        Json?    @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([originalProjectId])
  @@index([ownerId])
  @@index([managerId])
  @@index([serviceKey])
  @@index([niche])
  @@index([projectType])
  @@index([budgetMin])
  @@index([budgetMax])
  @@index([completedAt])
  @@map("CompletedProjects")
}

model BlogPost {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  excerpt        String         @db.Text
  content        String         @db.Text
  category       String?
  authorName     String         @default("Catalance Editorial Team")
  coverImageUrl  String?
  coverImageAlt  String?
  status         BlogPostStatus @default(DRAFT)
  featured       Boolean        @default(false)
  seoTitle       String?
  seoDescription String?        @db.Text
  seoKeywords    String[]       @default([])
  canonicalUrl   String?
  ogTitle        String?
  ogDescription  String?        @db.Text
  ogImageUrl     String?
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status, publishedAt])
  @@index([featured, status, publishedAt])
}

model Proposal {
  id                 String         @id @default(cuid())
  coverLetter        String         @db.Text
  amount             Int
  status             ProposalStatus @default(PENDING)
  rejectionReason    String?        @db.Text
  rejectionReasonKey String?
  followupGuidanceSent Boolean       @default(false)
  budgetReminderSent Boolean        @default(false)
  freelancer         User           @relation(fields: [freelancerId], references: [id])
  freelancerId       String
  project            Project        @relation(fields: [projectId], references: [id])
  projectId          String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([freelancerId])
  @@index([projectId, createdAt])
  @@index([projectId, status, createdAt])
}

model Dispute {
  id                  String        @id @default(cuid())
  description         String        @db.Text
  status              DisputeStatus @default(OPEN)
  resolutionNotes     String?       @db.Text
  meetingLink         String?
  meetingDate         DateTime?
  meetingReminderSent Boolean       @default(false)

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  raisedById String
  raisedBy   User   @relation("DisputeRaiser", fields: [raisedById], references: [id])

  managerId String?
  manager   User?   @relation("DisputeManager", fields: [managerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model ServiceCatalog {
  id            String   @id @default(cuid())
  key           String   @unique
  schemaVersion String?
  currency      String?
  payload       Json
  sourceFile    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ChatConversation {
  id           String        @id @default(cuid())
  service      String?
  projectTitle String?
  createdBy    User?         @relation("ChatCreator", fields: [createdById], references: [id])
  createdById  String?
  messages     ChatMessage[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([service])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  sender         User?            @relation("ChatSender", fields: [senderId], references: [id])
  senderId       String?
  senderName     String?
  senderRole     String?
  role           String           @default("user")
  content        String?          @db.Text
  attachment     Json? // store { name, size, type, url? }
  deleted        Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("general")
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  data      Json? // Extra data like link, relatedId etc.
  createdAt DateTime @default(now())

  @@index([userId])
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model ManagerAvailability {
  id        String   @id @default(cuid())
  managerId String
  manager   User     @relation("ManagerAvailability", fields: [managerId], references: [id])
  date      DateTime @db.Date
  startHour Int // 0-23 (e.g., 10 for 10:00 AM)
  endHour   Int // 0-23 (e.g., 11 for 11:00 AM)
  isBooked  Boolean  @default(false)
  isEnabled Boolean  @default(true)
  remark    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([managerId, date, startHour])
  @@index([managerId, date])
}

model Appointment {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  date        DateTime          @db.Date
  startHour   Int // 0-23
  endHour     Int // 0-23
  status      AppointmentStatus @default(PENDING)
  meetingLink String?

  // Who booked the appointment
  bookedById String
  bookedBy   User   @relation("AppointmentBooker", fields: [bookedById], references: [id])

  // Which manager's slot
  managerId String
  manager   User   @relation("AppointmentManager", fields: [managerId], references: [id])

  // Optional: related project
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId, date])
  @@index([bookedById])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id               String        @id @default(cuid())
  amount           Int // Total amount from client
  platformFee      Int           @default(0) // 30% platform fee
  freelancerAmount Int // Amount after fee (70%)
  currency         String        @default("INR")
  status           PaymentStatus @default(PENDING)
  description      String?       @db.Text

  payoutSequence    Int?
  payoutKey         String?
  payoutLabel       String?
  payoutPercentage  Int?
  payoutPhaseNumber Int?

  // Relations
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  freelancerId String
  freelancer   User   @relation("FreelancerPayments", fields: [freelancerId], references: [id])

  // Timestamps
  paidAt    DateTime? // When payment was released to freelancer
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([projectId, freelancerId, payoutSequence])
  @@index([freelancerId])
  @@index([projectId])
}

model Service {
  id          String  @id @default(cuid())
  slug        String  @unique // e.g. "branding", "web-dev"
  name        String
  description String?
  icon        String? // Optional icon name
  active      Boolean @default(true)
  aiPrompt    String? @db.Text // Custom AI instructions for this service
  proposalStructure String? @db.Text // Admin-managed proposal field order/template
  agencyProposalStructure String? @db.Text // Admin-managed multi-service agency proposal template
  internalProposalStructure String? @db.Text // Internal-only project proposalJson structure/template
  proposalPrompt    String? @db.Text // Proposal-specific AI instructions for this service

  minBudget Int?   @default(0)
  currency  String @default("INR")

  questions ServiceQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceQuestion {
  id String @id @default(cuid())

  slug String // The 'id' from JSON (e.g., 'project_requirements')

  text String @db.Text
  type String // 'input', 'single_option', 'multi_option'

  order Int @default(0)

  required Boolean @default(true)

  options Json? // [{ "label": "Red", "value": "red" }, ...]
  logic   Json? // [{ "condition": "equals", "value": "x", "nextQuestionSlug": "y" }]

  subtitle         String? // Context for AI
  saveResponse     Boolean @default(false) // Flag to save response for special handling
  showRecommendationPopup Boolean @default(false) // Auto-open recommendation helper for this question on the guest UI
  disableAutoRecommendationPopup Boolean @default(false) // Prevent automatic recommendation helper popups for this question
  nextQuestionSlug String? // Default next question if logic doesn't override

  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, slug])
}

model MarketplaceFilterService {
  id              Int                           @id @default(autoincrement())
  name            String                        @unique
  subCategories   MarketplaceFilterSubCategory[]
  freelancerSkills FreelancerSkill[]
  positiveKeywords ServicePositiveKeyword[]

  @@map("services")
}

model MarketplaceFilterSubCategory {
  id              Int                    @id @default(autoincrement())
  serviceId       Int                    @map("service_id")
  name            String
  service         MarketplaceFilterService @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tools           MarketplaceFilterTool[]
  freelancerSkills FreelancerSkill[]

  @@unique([serviceId, name])
  @@index([serviceId])
  @@map("sub_categories")
}

model MarketplaceFilterTool {
  id              Int                          @id @default(autoincrement())
  subCategoryId   Int                          @map("sub_category_id")
  name            String
  subCategory     MarketplaceFilterSubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  freelancerSkills FreelancerSkill[]

  @@unique([subCategoryId, name])
  @@index([subCategoryId])
  @@map("tools")
}

model MarketplaceFilterNiche {
  id   Int    @id @default(autoincrement())
  name String @unique

  @@map("Niches")
}

model ServicePositiveKeyword {
  id        Int                      @id @default(autoincrement())
  serviceId Int                      @map("service_id")
  name      String
  service   MarketplaceFilterService @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([serviceId, name])
  @@index([serviceId])
  @@map("service_positive_keywords")
}

model FreelancerSkill {
  id            Int                      @id @default(autoincrement())
  userId        String                   @map("user_id")
  serviceId     Int                      @map("service_id")
  subCategoryId Int                      @map("sub_category_id")
  toolId        Int                      @map("tool_id")
  createdAt     DateTime                 @default(now()) @map("created_at")
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  service       MarketplaceFilterService @relation(fields: [serviceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  subCategory   MarketplaceFilterSubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tool          MarketplaceFilterTool    @relation(fields: [toolId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, serviceId, subCategoryId, toolId])
  @@index([userId])
  @@index([serviceId])
  @@index([subCategoryId])
  @@index([toolId])
  @@map("freelancer_skills")
}

model AiGuestSession {
  id          String           @id @default(cuid())
  serviceId   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  currentStep Int              @default(0)
  answers     Json?            @default("{}")
  messages    AiGuestMessage[]
}

model AiGuestMessage {
  id        String         @id @default(cuid())
  sessionId String
  session   AiGuestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // "user" or "assistant"
  content   String         @db.Text
  createdAt DateTime       @default(now())

  @@index([sessionId, createdAt])
}

model ProjectTask {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  status      ProjectTaskStatus @default(TO_DO)
  deadline    DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Review {
  id         String   @id @default(cuid())
  serviceId  String
  clientName String
  clientId   String?
  rating     Int
  comment    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([serviceId])
  @@index([serviceId, clientId, createdAt])
}

model MilestoneApproval {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  managerId String
  manager   User     @relation("MilestoneApprover", fields: [managerId], references: [id])
  phase     Int
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([projectId, phase])
  @@index([managerId])
}

model InternalFreelancerReview {
  id           String   @id @default(cuid())
  freelancerId String
  freelancer   User     @relation("ReviewSubject", fields: [freelancerId], references: [id])
  managerId    String
  manager      User     @relation("ReviewAuthor", fields: [managerId], references: [id])
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  rating       Int?
  strengths    String?  @db.Text
  issues       String?  @db.Text
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([freelancerId])
  @@index([managerId])
  @@index([projectId])
}

model AdminEscalation {
  id          String        @id @default(cuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id])
  raisedById  String
  raisedBy    User          @relation("EscalationRaiser", fields: [raisedById], references: [id])
  reason      String
  description String        @db.Text
  status      DisputeStatus @default(OPEN)
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([projectId])
  @@index([raisedById])
}

model ProfileUpdateRequest {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("ProfileUpdateUser", fields: [userId], references: [id])
  userRole        String         @default("PROJECT_MANAGER")
  status          ProposalStatus @default(PENDING)
  requestedData   Json
  reviewedById    String?
  reviewedBy      User?          @relation("ProfileUpdateReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  rejectionReason String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
}

model EngagementProfile {
  id                    String          @id @default(cuid())
  userId                String          @unique
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  engagementLevel       EngagementLevel @default(LEVEL_1)
  xp                    Int             @default(0)
  lifetimeXp            Int             @default(0)
  loyaltyCoins          Int             @default(0)
  lifetimeCoinsEarned   Int             @default(0)
  lifetimeCoinsSpent    Int             @default(0)
  currentStreak         Int             @default(0)
  longestStreak         Int             @default(0)
  lastCompletedDayKey   String?
  timezone              String          @default("UTC")
  freezeTokens          Int             @default(0)
  dailyCompletionCount  Int             @default(0)
  totalQuestionsAnswered Int            @default(0)
  totalCorrectAnswers   Int             @default(0)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([engagementLevel])
  @@index([currentStreak])
  @@index([lastCompletedDayKey])
}

model EngagementQuestion {
  id              String                     @id @default(cuid())
  questionText    String                     @db.Text
  type            EngagementQuestionType     @default(MCQ)
  category        EngagementQuestionCategory
  skillTag        String
  difficulty      EngagementDifficulty       @default(BEGINNER)
  options         Json
  correctOptionId String
  explanation     String                     @db.Text
  source          String                     @default("template")
  status          EngagementQuestionStatus   @default(DRAFT)
  aiMetadata      Json                       @default("{}")
  contentHash     String                     @unique
  usageCount      Int                        @default(0)
  successRate     Float?
  rejectedReason  String?                    @db.Text
  approvedById    String?
  approvedBy      User?                      @relation("EngagementQuestionApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([status, category, difficulty])
  @@index([skillTag])
  @@index([approvedById])
}

model DailyQuestionSet {
  id           String                 @id @default(cuid())
  dayKey       String                 @unique
  questionIds  String[]               @default([])
  status       DailyQuestionSetStatus @default(DRAFT)
  generatedBy  String                 @default("fallback")
  approvedById String?
  approvedBy   User?                  @relation("DailyQuestionSetApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  publishedAt  DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  sessions     EngagementAnswerSession[]

  @@index([status, dayKey])
  @@index([approvedById])
}

model EngagementAnswerSession {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation("EngagementAnswerUser", fields: [userId], references: [id], onDelete: Cascade)
  dayKey             String
  dailyQuestionSetId String?
  dailyQuestionSet   DailyQuestionSet? @relation(fields: [dailyQuestionSetId], references: [id], onDelete: SetNull)
  answers            Json
  questionSnapshots  Json             @default("[]")
  totalScore         Int              @default(0)
  correctCount       Int              @default(0)
  questionCount      Int              @default(0)
  accuracy           Float            @default(0)
  xpAwarded          Int              @default(0)
  coinsAwarded       Int              @default(0)
  resultSummary      Json             @default("{}")
  idempotencyKey     String?          @unique
  streakApplied      Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([dayKey])
  @@index([dailyQuestionSetId])
}

model PointsLedger {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation("EngagementPointsUser", fields: [userId], references: [id], onDelete: Cascade)
  amount         Int
  type           PointsLedgerType
  reason         String
  referenceType  String?
  referenceId    String?
  balanceAfter   Int
  idempotencyKey String           @unique
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([referenceType, referenceId])
}

model EngagementBadge {
  id            String                @id @default(cuid())
  key           String                @unique
  title         String
  description   String                @db.Text
  milestoneDays Int?
  icon          String                @default("award")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  userBadges    EngagementUserBadge[]
}

model EngagementUserBadge {
  id       String            @id @default(cuid())
  userId   String
  user     User              @relation("EngagementBadgeUser", fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    EngagementBadge   @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  key      String
  earnedAt DateTime          @default(now())

  @@unique([userId, key])
  @@index([badgeId])
}

model EngagementProcessReport {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollingAccuracy       Float    @default(0)
  rolling7DayAccuracy   Float    @default(0)
  topicStats            Json     @default("{}")
  weakTopics            String[] @default([])
  strongTopics          String[] @default([])
  recommendedNextTopic  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model EngagementPersonalizedQuestion {
  id                   String   @id
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey               String
  questionId           String?
  questionText         String   @db.Text
  category             String
  difficulty           String
  skillTag             String?
  focusReason          String?  @db.Text
  generationSource     String   @default("fallback")
  sourceReportSnapshot Json     @default("{}")
  aiMetadata           Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, dayKey])
  @@index([dayKey])
  @@map("EngagementPersonalizedQuestion")
}

model EngagementAdminAuditLog {
  id           String   @id @default(cuid())
  adminId      String?
  admin        User?    @relation("EngagementAuditAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  targetUserId String?
  targetUser   User?    @relation("EngagementAuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  action       String
  entityType   String
  entityId     String?
  oldValue     Json?
  newValue     Json?
  reason       String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([entityType, entityId])
}
