{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["bom1"],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "excludeFiles": "{.env,.env.*,dist/**,**/*.map,**/*.d.ts}"
    }
  },
  "rewrites": [
    {
      "source": "/:path((?!api/index).*)",
      "destination": "/api/index"
    }
  ]
}
